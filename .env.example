# ============================================================
# CashFlow JDG — zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości
# ============================================================

# --- Baza danych (SQLite) ---
# Lokalnie: ścieżka do pliku dev.db
DATABASE_URL="file:./dev.db"
# W Dockerze: DATABASE_URL="file:/data/finance.db"

# --- Bezpieczeństwo ---
# Hasło dostępu do aplikacji (zostaw puste, żeby wyłączyć)
APP_PASSWORD=""

# Sekret do szyfrowania sesji — ZMIEŃ na produkcji!
# Wygeneruj: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# --- Docker / Traefik (opcjonalne) ---
DOMAIN="cashflow.yourdomain.com"

# ============================================================
# Poniższe zmienne są konfigurowane przez UI (Ustawienia)
# i przechowywane w bazie danych — NIE ma potrzeby ich
# ustawiać tutaj. Opisane poglądowo.
# ============================================================

# Ollama AI (konfiguracja w Ustawienia → Lokalne AI)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2   # lub llava (OCR), mistral, gemma2

# SMTP Email (konfiguracja w Ustawienia → Powiadomienia)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=jan@gmail.com
# SMTP_PASS=app-password    # Dla Gmail: App Password z 2FA

# KSeF (konfiguracja w Ustawienia → KSeF)
# KSEF_TOKEN=token-z-portalu-podatnika
# KSEF_ENV=test             # lub: prod
